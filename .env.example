# Copy this file to `.env` on your laptop and on the droplet.
# Never commit the real .env — it is excluded by .gitignore.

# ---- Supabase HTTPS (existing) ----
# From Supabase dashboard → Project Settings → API.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me

# These NEXT_PUBLIC_* duplicates exist because Supabase's quickstart adds them
# for browser/Next.js clients. Harmless to keep; this pipeline does not use them.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me

# ---- Supabase Postgres direct connection (needed by this pipeline) ----
# This is the one you need to add to your .env.
# Supabase dashboard → Project Settings → Database → Connection string → "Transaction pooler".
# Copy the URI form. Replace [YOUR-PASSWORD] with your DB password.
# Shape: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres

# ---- Operator contact for User-Agent strings ----
# SEC EDGAR in particular requires a contact email in the User-Agent header.
OPERATOR_CONTACT_EMAIL=you@example.com
USER_AGENT=news-archive-pipeline/0.1 (+mailto:you@example.com)

# ---- Environment name ----
# "local" | "droplet" — tagged into logs and collection_runs.notes so we know where a row came from.
ENVIRONMENT=local

# ---- Log level ----
LOG_LEVEL=INFO

# ---- Alerts (wired up in Week 4, leave blank for now) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# ---- Healthchecks.io (Week 4) ----
HEALTHCHECKS_URL=
